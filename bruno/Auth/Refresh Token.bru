meta {
  name: Refresh Token
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/auth/refresh
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{authToken}}
}

script:post-response {
  const body = res.getBody();
  if (body && body.token) {
    bru.setVar("authToken", body.token);
  }
}
