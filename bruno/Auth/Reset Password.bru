meta {
  name: Reset Password
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/api/auth/reset-password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "{{resetToken}}",
    "password": "change-me-please",
    "confirmPassword": "change-me-please"
  }
}
