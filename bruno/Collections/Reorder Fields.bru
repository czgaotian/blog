meta {
  name: Reorder Fields
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/admin/collections/{{collectionId}}/fields/reorder
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{authToken}}
  Content-Type: application/json
}

body:json {
  {
    "fieldIds": [
      "{{fieldId}}"
    ]
  }
}
