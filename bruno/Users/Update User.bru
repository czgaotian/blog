meta {
  name: Update User
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/admin/users/{{userId}}
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{authToken}}
  Content-Type: application/json
}

body:json {
  {
    "role": "editor",
    "firstName": "Editor",
    "lastName": "Updated",
    "isActive": true
  }
}
