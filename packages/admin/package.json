{
  "name": "@worker-blog/admin",
  "version": "0.1.0",
  "private": true,
  "description": "Admin UI package for Worker Blog",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit && vite build && wrangler deploy --config ../server/wrangler.toml --dry-run",
    "cf-typegen": "wrangler types --config ../server/wrangler.toml",
    "deploy": "pnpm run build && wrangler deploy --config ../server/wrangler.toml",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest --run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.101.0",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-horizontal-rule": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-list": "^3.26.0",
    "@tiptap/extension-subscript": "^3.26.0",
    "@tiptap/extension-superscript": "^3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/extension-typography": "^3.26.0",
    "@tiptap/extensions": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@worker-blog/shared": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "react-hotkeys-hook": "^5.3.2",
    "react-router": "^7.16.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@cloudflare/vite-plugin": "^1.39.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "postcss": "^8.5.15",
    "sass-embedded": "^1.100.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.97.0"
  }
}
