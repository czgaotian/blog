{
  "name": "@worker-blog/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared contracts and utilities for Worker Blog packages",
  "type": "module",
  "scripts": {
    "test": "vitest --run"
  },
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth/index.ts",
    "./auth/*": "./src/auth/*.ts",
    "./routes": "./src/routes/index.ts",
